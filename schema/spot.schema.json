{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Climbing Spot",
  "description": "A climbing spot contribution for OnSight",
  "type": "object",
  "required": ["name", "lat", "lon", "climbing_type"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Name of the climbing spot"
    },
    "type": {
      "type": "string",
      "enum": ["outdoor", "indoor"],
      "default": "outdoor",
      "description": "Spot type: outdoor crag or indoor gym"
    },
    "lat": {
      "type": "number",
      "minimum": -90,
      "maximum": 90,
      "description": "WGS84 latitude"
    },
    "lon": {
      "type": "number",
      "minimum": -180,
      "maximum": 180,
      "description": "WGS84 longitude"
    },
    "climbing_type": {
      "type": "string",
      "pattern": "^(sport|boulder|trad|multi-pitch)(,(sport|boulder|trad|multi-pitch))*$",
      "description": "Comma-separated climbing types: sport, boulder, trad, multi-pitch"
    },
    "photo_url": {
      "type": "string",
      "format": "uri",
      "description": "Optional URL to a photo of the spot"
    }
  }
}
